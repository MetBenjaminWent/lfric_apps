set -e

EXEC_NAME="$1"

echo "Running Pat build script"

# This is where the executable is found
EXEC_PATH="${BIN_DIR}/${EXEC_NAME}"
echo "${EXEC_PATH}"

PAT_LIBS=

# Test we are in the bin dir, otherwise the exe will end up in the wrong place
cd "${BIN_DIR}"
rm -f "${EXEC_NAME}+pat"

# Call pat_build on the executable
# Unfortunately, we have to use these flags:
# -w :
pat_build -u -g pnetcdf,io "${EXEC_NAME}" -Vv
